# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA comite o arquivo .env no repositório

# Banco de dados
# Para SQLite (desenvolvimento local):
DATABASE_URL=sqlite:///./aussistencia.db

# Para PostgreSQL (produção):
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/aussistencia

# Segurança JWT
SECRET_KEY=troque-esta-chave-por-uma-string-aleatoria-longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
